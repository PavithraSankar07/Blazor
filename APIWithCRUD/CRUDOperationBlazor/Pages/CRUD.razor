@page "/"
@using System.Net.Http.Json
@using System.IO
@using Microsoft.AspNetCore.Hosting
@using static CRUDOperation.Models.PersonalInfo
@inject HttpClient Http
@inject IWebHostEnvironment env

<h1>User List</h1>
<EditForm Model="newInfo" OnValidSubmit="SaveInfo">
    <div class="form-input">
        <label for="nameInput">Name:</label>
        <input type="text" @bind="newInfo.Name" placeholder="Name">
    </div>
    <div class="form-input">
        <label for="nameInput">MailID:</label>
        <input type="text" @bind="newInfo.MailID" placeholder="MailID">
    </div>
    <div class="form-input">
        <label for="nameInput">MobileNumber:</label>
        <input type="text" @bind="newInfo.Mobile" placeholder="MobileNumber">
    </div>
    <div class="form-input">
        <label>Photo:</label>
        <InputFile OnChange="PhotoUpload" />

        @if (!string.IsNullOrEmpty(newInfo.Photo))
        {
            <div>
                <img src="@newInfo.Photo" alt="Uploaded Photo" style="max-width: 150px; max-height: 150px;" />
            </div>
        }

    </div>
    <div class="form-input">
        <label>Degree:</label>
        <InputSelect @bind-Value="newInfo.Degree" TValue="string">
            <option value="">Select Degree</option>
            @foreach (var dept in Degrees)
            {
                <option value="@dept">@dept</option>
            }
        </InputSelect>
    </div>
    @if (!string.IsNullOrEmpty(newInfo.Degree))
    {
        <div class="form-input">
            <textarea @bind="newInfo.Department" placeholder="Enter your Department here"></textarea>

        </div>
    }
    <div class="form-input">
        <label for="nameInput">DOB:</label>
        <InputDate @bind-Value="newInfo.DOB" />


    </div>
    <div class="form-input">
        <label for="nameInput">Department:</label>
        <select multiple @bind="newInfo.SelectedDepartments">
            @foreach (var dept in departments)
            {
                <option value="@dept">@dept</option>
            }
        </select>
    </div>
    <div class="form-input">
        <label for="nameInput">Time:</label>
        <InputText @bind-Value="newInfo.Time" type="time"></InputText>
    </div>
    <div class="form-input">
        <label>Gender:</label>
        <div class="input-inline-group">
            <InputRadioGroup @bind-Value="newInfo.Gender">
                <InputRadio id="male" Value="GenderEnum.Male" />
                <label for="male">Male</label>

                <InputRadio id="female" Value="GenderEnum.Female" />
                <label for="female">Female</label>

                <InputRadio id="other" Value="GenderEnum.Other" />
                <label for="other">Other</label>
            </InputRadioGroup>
        </div>
    </div>
    <div class="form-input">
        <label>Language:</label>
        <div class="input-inline-group">
            @foreach (var lang in languages)
            {
                <input type="checkbox" checked="@newInfo.Languages.Contains(lang)" @onchange="e => Language(lang, e)" />
                <label>@lang</label>
            }
        </div>
    </div>
    <div class="form-input">
        <label>DateTime:</label>
        <input type="datetime-local" @bind="newInfo.DateTime" />
    </div>
    <div class="form-input">
        <label>Amount:</label>
        <input type="number" @bind="newInfo.Amount" />
    </div>
    <br>
    <InputFile OnChange="HandleFileSelected" />
    <button type="submit">@button</button>
</EditForm>
<hr />
@* <h1>Data</h1> *@
<table>
    <thead>
        <tr>
            <th>Name</th>
            <th>ID</th>
            <th>Mobile</th>
            <th>MailID</th>
            <th>Degree</th>
            <th>Departments</th>
            <th>Photo</th>
            <th>DOB</th>
            <th>Selected</th>
            <th>Gender</th>
            <th>Time</th>
            <th>Language</th>
            <th>DateTime</th>
            <th>File</th>
            <th>Amount</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var info in personalInfos)
        {
            <tr>
                <td>@info.Name</td>
                <td>@info.ID</td>
                <td>@info.Mobile</td>
                <td>@info.MailID</td>
                <td>@info.Degree</td>
                <td>@info.Department</td>
                <td>@if (!string.IsNullOrEmpty(info.Photo))
                    {
                        <img src="@info.Photo" alt="Uploaded Image" style="max-width: 300px; max-height: 300px;" />
                    }
                                else
                    {
                        <span>No Photo</span>
                    }
                </td>
                <td>@info.DOB.ToString("dd/MM/yyyy")</td>

                <td>@(info.SelectedDepartments != null ? string.Join(", ", info.SelectedDepartments) : "")
                </td>
                <td>@info.Gender</td>
                <td>@info.Time</td>

                <td>@(info.Languages?.Count > 0 ? string.Join(", ", info.Languages) : "No languages selected")</td>

                <td>@info.DateTime.ToString("dd/MM/yyyy HH:mm")</td>

                @if (!string.IsNullOrEmpty(filePreviewUrl))
                {
                    <a href="@filePreviewUrl" download="@uploadedFile.Name">Download @uploadedFile.Name</a>
                }

                <td>@info.Amount</td>

                <td>
                    <button @onclick="() => EditInfo(info)">Edit</button>
                    <button @onclick="() => DeleteInfo(info)">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private IBrowserFile uploadedFile;
    private string filePreviewUrl;

  private async Task HandleFileSelected(InputFileChangeEventArgs e)
{
    uploadedFile = e.File;
    using var stream = uploadedFile.OpenReadStream(maxFileSize);
    var buffer = new byte[uploadedFile.Size];
    await stream.ReadAsync(buffer);
    newInfo.File = $"data:{uploadedFile.ContentType};base64,{Convert.ToBase64String(buffer)}";
    filePreviewUrl = newInfo.File;
}

    public const long maxFileSize = 1024 * 1024 * 5;
    public async Task PhotoUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            using var stream = file.OpenReadStream(maxFileSize);
            var fileSize = new byte[file.Size];
            await stream.ReadAsync(fileSize);

            newInfo.Photo = $"data:{file.ContentType};base64,{Convert.ToBase64String(fileSize)}";
        }
    }
    private List<string> languages = new() { "English", "Spanish", "French", "Hindi" };
    private void Language(string lang, ChangeEventArgs e)
    {
        bool isChecked = e.Value?.ToString().ToLower() == "true";

        if (isChecked)
        {
            if (!newInfo.Languages.Contains(lang))
                newInfo.Languages.Add(lang);
        }
        else
        {
            if (newInfo.Languages.Contains(lang))
                newInfo.Languages.Remove(lang);
        }
    }
    List<string> departments = new() { "HR", "Sales", "IT", "Finance", "Marketing" };
    List<string> Degrees = new List<string>
{
"Bachelor of Degree","Master of Degree", "Engineering"
};
    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            var buffer = new byte[file.Size];
            await file.OpenReadStream().ReadAsync(buffer);
            string imageBase64Data = Convert.ToBase64String(buffer);
            string imageDataUrl = $"data:{file.ContentType};base64,{imageBase64Data}";
            newInfo.Photo = imageDataUrl;
        }
    }

    List<PersonalInfo> personalInfos = new();
    PersonalInfo newInfo = new();
    bool isEdit = false;
    PersonalInfo selectedInfo;
    string button = "Add";

    @* protected override async Task OnInitializedAsync()
    {
        await LoadData();
    } *@

    async Task LoadData()
    {
        personalInfos = await Http.GetFromJsonAsync<List<PersonalInfo>>("api/Personal");
        StateHasChanged();
    }
    async Task SaveInfo()
    {
        if (isEdit)
        {
            var putResponse = await Http.PutAsJsonAsync($"api/Personal/{selectedInfo.ID}", newInfo);
            isEdit = false;
            button = "Add";
        }
        else
        {
            var postResponse = await Http.PostAsJsonAsync("api/Personal", newInfo);
            if (!postResponse.IsSuccessStatusCode)
            {
                var errorText = await postResponse.Content.ReadAsStringAsync();
                Console.WriteLine($"POST failed: {postResponse.StatusCode}");
                Console.WriteLine($"Error response: {errorText}");
            }
        }

        await LoadData();
        newInfo = new PersonalInfo();
    }
    async Task DeleteInfo(PersonalInfo info)
    {
        await Http.DeleteAsync($"api/Personal/{info.ID}");
        await LoadData();
    }

    void EditInfo(PersonalInfo info)
    {
        isEdit = true;
        selectedInfo = info;
        newInfo = new PersonalInfo
        {
            ID = selectedInfo.ID,
            Name = selectedInfo.Name,
            Mobile = selectedInfo.Mobile,
            MailID = selectedInfo.MailID,
            Photo = selectedInfo.Photo,
            Degree = selectedInfo.Degree,
            Department = selectedInfo.Department,
            DOB = selectedInfo.DOB,
            Time = selectedInfo.Time,
            Languages = selectedInfo.Languages,
            DateTime = selectedInfo.DateTime,
            Amount = selectedInfo.Amount,
            Gender = selectedInfo.Gender,File=selectedInfo.File,
            SelectedDepartments = selectedInfo.SelectedDepartments != null ? selectedInfo.SelectedDepartments.ToArray() :
        Array.Empty<string>()
        };

        button = "Update";
    }


}
