string styleColor;
string displaymessage;

   
      private string fileStatus;
   private async Task UploadFile(InputFileChangeEventArgs e)
{
    var file = e.File;

    if (file == null)
    {
        fileStatus = "No file selected.";
        newInfo.File = null;  
        return;
    }

    if (file.Size > maxFileSize)
    {
        fileStatus = "File too large. Max 10 MB.";
        return;
    }

    try
    {
        var uploadFolder = Path.Combine(env.WebRootPath, "uploads");
        Directory.CreateDirectory(uploadFolder);
        var filePath = Path.Combine(uploadFolder, file.Name);
        await using var stream = new FileStream(filePath, FileMode.Create);
        await file.OpenReadStream(maxFileSize).CopyToAsync(stream);
        newInfo.File = file.Name;

        fileStatus = $"File '{file.Name}' uploaded successfully!";
    }
    catch (Exception ex)
    {
        fileStatus = $"Upload failed: {ex.Message}";
    }
}
  private List<string> languages = new() { "English", "Spanish", "French", "Hindi" };
