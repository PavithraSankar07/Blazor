            <th>Name</th>
            <th>Mobile</th>
            <th>MailID</th>
            <th>Degree</th>
            <th>Course</th>
            <th>Photo</th>
            <th>DOB</th>
            <th>Team</th>
            <th>Gender</th>
            <th>Chech-In Time</th>
            <th>Language</th>
            <th>Joining Date</th>
            <th>Resume</th>
            <th>Amount</th>
            <th>Actions</th>
        </tr>
    </thead>
