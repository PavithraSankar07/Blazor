   private void Language(string lang, ChangeEventArgs e)
{
    bool isChecked = e.Value?.ToString().ToLower() == "true";

    if (isChecked)
    {
        if (!newInfo.Languages.Contains(lang))
            newInfo.Languages.Add(lang);
    }
    else
    {
        if (newInfo.Languages.Contains(lang))
            newInfo.Languages.Remove(lang);
    }
}


    List<string> departments = new() { "CSE", "ECE", "IT", "EEE" };

    private static int s_id = 1;
    List<PersonalInfo> personalInfos = new List<PersonalInfo>();
    List<string> Degrees = new List<string>
{
"Bachelor of Arts","Master of Arts", "Engineering", "Bachelor of Science", "Master of Science"
};


    string button = "Add";
    bool isEdit = false;
    PersonalInfo selectedInfo;

    public const long maxFileSize = 1024 * 1024 * 5;

    public async Task PhotoUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            using var stream = file.OpenReadStream(maxFileSize);
            var fileSize = new byte[file.Size];
            await stream.ReadAsync(fileSize);

            newInfo.Photo = $"data:{file.ContentType};base64,{Convert.ToBase64String(fileSize)}";
        }
    }
    @* Edit the data *@
    public void EditInfo(PersonalInfo personal)
    {
        isEdit = true;
        selectedInfo = personal;

        newInfo.ID = personal.ID;
        newInfo.Name = personal.Name;
        newInfo.Mobile = personal.Mobile;
        newInfo.MailID = personal.MailID;
        newInfo.Photo = personal.Photo;
        newInfo.Degree = personal.Degree;
        newInfo.Department = personal.Department;
        newInfo.DOB = personal.DOB;
        newInfo.SelectedDepartments = personal.SelectedDepartments;
        newInfo.Time = personal.Time;
        newInfo.Languages = personal.Languages;
        newInfo.DateTime = personal.DateTime;
        newInfo.File = personal.File;
        newInfo.Gender=personal.Gender;
        newInfo.Amount=personal.Amount;


        button = "Update";
    }
    @* Create the form *@

    private async Task SaveInfo()

    {
        if(editContext.Validate())
        {
        if (isEdit)
        {
            @* selectedInfo.ID = newInfo.ID; *@
            selectedInfo.Name = newInfo.Name;
            selectedInfo.Mobile = newInfo.Mobile;
            selectedInfo.MailID = newInfo.MailID;
            selectedInfo.Photo = newInfo.Photo;
            selectedInfo.Degree = newInfo.Degree;
            selectedInfo.Department = newInfo.Department;
            selectedInfo.DOB = newInfo.DOB;
            selectedInfo.SelectedDepartments = newInfo.SelectedDepartments;
            selectedInfo.Time = newInfo.Time;
           selectedInfo.Languages = newInfo.Languages;
            selectedInfo.DateTime = newInfo.DateTime;
            selectedInfo.File = newInfo.File;
            selectedInfo.Gender = newInfo.Gender;
            selectedInfo.Amount=newInfo.Amount;

            isEdit = false;
            button = "Add";
        }
        else
        {
             
            newInfo.ID = s_id++;
            personalInfos.Add(new PersonalInfo
            {
                ID = newInfo.ID,
                Name = newInfo.Name,
                Mobile = newInfo.Mobile,
                MailID = newInfo.MailID,
                Photo = newInfo.Photo,
                Degree = newInfo.Degree,
                Department = newInfo.Department,
                DOB = newInfo.DOB,
                SelectedDepartments = newInfo.SelectedDepartments,
                Time = newInfo.Time,
                Languages = newInfo.Languages,
                DateTime = newInfo.DateTime,File=newInfo.File,Gender=newInfo.Gender,Amount=newInfo.Amount
            });
        }
        }
