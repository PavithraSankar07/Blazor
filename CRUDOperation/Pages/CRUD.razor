        @foreach (PersonalInfo personalInfo in personalInfos)
        {
            <tr>
                <td>@personalInfo.Name</td>
                <td>@personalInfo.ID</td>
                <td>@personalInfo.Mobile</td>
                <td>@personalInfo.MailID</td>
                <td>@personalInfo.Degree</td>
                <td>@personalInfo.Department</td>
                <td>@if (!string.IsNullOrEmpty(personalInfo.Photo))
                    {
                        <img src="@personalInfo.Photo" alt="Uploaded Image" style="max-width: 300px; max-height: 300px;" />
                    }
                                else
                    {
                        <span>No Photo</span>
                    }
                </td>
                <td>@personalInfo.DOB.ToString("dd/MM/yyyy")</td>
                @* <td>@personalInfo.SelectedDepartments</td> *@
                <td>@(personalInfo.SelectedDepartments != null ? string.Join(", ", personalInfo.SelectedDepartments) : "")
                </td>
                <td>@personalInfo.Gender</td>
                <td>@personalInfo.Time</td>
               
            <td>@(personalInfo.Languages?.Count > 0 ? string.Join(", ", personalInfo.Languages) : "No languages selected")</td>

                <td>@personalInfo.DateTime.ToString("dd/MM/yyyy HH:mm")</td>

<td>
    @if (!string.IsNullOrEmpty(personalInfo.File))
    {
        <a href="@($"uploads/{personalInfo.File}")" target="_blank">@personalInfo.File</a>
    }
    else
    {
        <span>No File</span>
    }
</td>
<td>@personalInfo.Amount</td>

                <td>
                    <button @onclick="() => EditInfo(personalInfo)">Edit</button>
                    <button @onclick="() => DeleteInfo(personalInfo)">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>


