    public async Task PhotoUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            using var stream = file.OpenReadStream(maxFileSize);
            var fileSize = new byte[file.Size];
            await stream.ReadAsync(fileSize);

            newInfo.Photo = $"data:{file.ContentType};base64,{Convert.ToBase64String(fileSize)}";
        }
    }
    @* Edit the data *@
    public void EditInfo(PersonalInfo personal)
    {
        isEdit = true;
        selectedInfo = personal;

        newInfo.ID = personal.ID;
        newInfo.Name = personal.Name;
        newInfo.Mobile = personal.Mobile;
        newInfo.MailID = personal.MailID;
        newInfo.Photo = personal.Photo;
        newInfo.Degree = personal.Degree;
        newInfo.Department = personal.Department;
        newInfo.DOB = personal.DOB;
        newInfo.SelectedDepartments = personal.SelectedDepartments;
        newInfo.Time = personal.Time;
        newInfo.Languages = personal.Languages;
        newInfo.DateTime = personal.DateTime;
        newInfo.File = personal.File;
        newInfo.Gender=personal.Gender;
        newInfo.Amount=personal.Amount;


        button = "Update";
    }
