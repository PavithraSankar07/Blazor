@page "/"
@using System.IO
@using Microsoft.AspNetCore.Hosting
@using static CRUDOperation.Models.PersonalInfo
@using System.ComponentModel.DataAnnotations
@inject IJSRuntime JSRuntime
@inject IWebHostEnvironment env

<EditForm EditContext="editContext" OnValidSubmit="SaveInfo">
    <DataAnnotationsValidator/>
    <div class="form-matrix">
<div class="row1">
<div class="form-input">
     <label for="nameInput">Name:</label>
    <InputText  @bind-Value="newInfo.Name" placeholder="Name" onblur="@(()=>validatefield(nameof(newInfo.Name)))"/>
    <ValidationMessage For="@(()=>newInfo.Name)"></ValidationMessage>
</div>
<div class="form-input">
    <label for="nameInput">MailID:</label>
    <InputText @bind-Value="newInfo.MailID" placeholder="MailID" onblur="@(()=>validatefield(nameof(newInfo.MailID)))"/>
<ValidationMessage For="@(()=>newInfo.MailID)"></ValidationMessage>
</div>
<div class="form-input">
    <label for="nameInput">MobileNumber:</label>
    <InputNumber @bind-Value="newInfo.Mobile" placeholder="MobileNumber"/>
    <ValidationMessage For="@(()=>newInfo.Mobile)"></ValidationMessage>
</div>
<div class="form-input">
    <label>Photo:</label>
    <InputFile OnChange="PhotoUpload" onblur="@(()=>validatefield(nameof(newInfo.Photo)))" />
    
    @if (!string.IsNullOrEmpty(newInfo.Photo))
    {
        <div>
            <img src="@newInfo.Photo" alt="Uploaded Photo" style="max-width: 150px; max-height: 150px;" />
        </div>
    }
    <ValidationMessage For="@(()=>newInfo.Photo)"></ValidationMessage>
</div>
<div class="form-input">
  <label>Gender:</label>
  <InputRadioGroup @bind-Value="newInfo.Gender" class="gender-group">
    <div class="gender">
      <InputRadio Value="GenderEnum.Male" /> <span>Male</span>
    </div>
    <div class="gender1">
      <InputRadio Value="GenderEnum.Female" /> <span>Female</span>
    </div>
    <div class="gender2">
      <InputRadio Value="GenderEnum.Other" /> <span>Other</span>
    </div>
  </InputRadioGroup>
  <ValidationMessage For="@(()=>newInfo.Gender)"></ValidationMessage>
</div>
</div>

<div class="row2">
@* <div class="form-input">
    <label for="nameInput">Degree:</label>
    <InputSelect @bind-Value="newInfo.Degree">
        <option value="">Select Degree</option>
        @foreach (var dept in Degrees)
        {
            <option value="@dept">@dept</option>
        }
    </InputSelect>
    <ValidationMessage For="@(()=>newInfo.Degree)"></ValidationMessage>
</div> *@
@* @if (!string.IsNullOrEmpty(newInfo.Degree))
{
    <div class="form-input">
        <textarea @bind="newInfo.Department" placeholder="Enter your Department here"></textarea>
    </div>
} *@
<div class="form-input">
    <label for="nameInput">DOB:</label>
   <InputDate @bind-Value="newInfo.DOB"/>
   <ValidationMessage For="@(()=>newInfo.DOB)"></ValidationMessage>
</div>



<div class="form-input">
  <label>Language:</label>
  <div class="language-group">
    @foreach (var lang in languages)
{
    <input 
        type="checkbox" 
        checked="@newInfo.Languages.Contains(lang)" 
        @onchange="(e) => OnLanguageChanged(lang, ((ChangeEventArgs)e).Value)" />
    <label>@lang</label>
}
  </div>
  <ValidationMessage For="@(()=>newInfo.Languages)"></ValidationMessage>
</div>
<div class="form-input">
    <label for="nameInput">Department:</label>
    <InputSelect multiple @bind="newInfo.SelectedDepartments" TValue="List<string>">
        @foreach (var dept in departments)
   
{
        <option value="@dept">@dept</option>
        }
    </InputSelect>
</div>
</div>

<ValidationMessage For="@(()=>newInfo.Department)"></ValidationMessage>
<div class="row3">
<div class="form-input">
<label for="nameInput">Check-In Time:</label>
<InputText @bind-Value="newInfo.Time" type="time"></InputText>
</div>
<ValidationMessage For="@(()=>newInfo.Time)"></ValidationMessage>
<div class="form-input">
        <label>Joining Date:</label>
        <InputDate @bind-Value="newInfo.DateTime" />
    </div>
<ValidationMessage For="@(()=>newInfo.DateTime)"></ValidationMessage>
    <div class="form-input">
        <label>Amount:</label>
        <InputNumber @bind-Value="newInfo.Amount" />
    </div>
    <ValidationMessage For="@(()=>newInfo.Amount)"></ValidationMessage>
    <div class="form-input">
    <label for="nameInput">Resume:</label>
<InputFile OnChange="UploadFile" accept=".pdf,.doc,.docx,.txt" />
</div>
<ValidationMessage For="@(()=>newInfo.File)"></ValidationMessage>
</div>
</div>
<br>
<br>
<button type="submit">@button</button>
<p style="color: @styleColor">@displaymessage</p>

</EditForm>
<h2>User List</h2>
